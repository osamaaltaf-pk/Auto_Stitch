# .env.example — copy to .env and edit for your machine
# .env is gitignored; .env.example is committed

# UI settings
AUTOSTITCH_UI_PORT=8080
AUTOSTITCH_THEME=dark

# Override model directories if your models are on a different drive
# AUTOSTITCH_SFX_MODEL_DIR=D:/models/stable_audio
# AUTOSTITCH_TTS_MODEL_DIR=D:/models/pocket_tts

# Override output directory
# AUTOSTITCH_OUTPUT_DIR=D:/renders/autostitch

# Set to 1 to enable verbose engine logging (slow, for debugging only)
# AUTOSTITCH_ENGINE_DEBUG=0
